#!/bin/bash
set -euo pipefail

DOTFILES_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
COMMON_DIR="$DOTFILES_DIR/scripts/common"

echo "=== Dotfiles Bootstrap ==="

case "$(uname -s)" in
Darwin)
    echo "Detected macOS"
    SCRIPTS_DIR="$DOTFILES_DIR/scripts/macos"
    "$SCRIPTS_DIR/brew.sh"
    # Make Homebrew-installed tools available to subsequent scripts
    eval "$(/opt/homebrew/bin/brew shellenv 2>/dev/null || /usr/local/bin/brew shellenv 2>/dev/null || true)"
    ;;
Linux)
    echo "Detected Linux"
    if command -v apt-get &>/dev/null; then
        SCRIPTS_DIR="$DOTFILES_DIR/scripts/ubuntu"
    else
        echo "Unsupported Linux distribution (no apt-get found)."
        exit 1
    fi
    "$SCRIPTS_DIR/apt.sh"
    "$SCRIPTS_DIR/neovim.sh"
    "$SCRIPTS_DIR/rustup.sh"
    "$SCRIPTS_DIR/uv.sh"
    ;;
*)
    echo "Unsupported OS: $(uname -s)"
    exit 1
    ;;
esac

"$COMMON_DIR/oh-my-zsh.sh"
"$COMMON_DIR/stow.sh"
"$COMMON_DIR/nvm.sh"

echo ""
echo "=== Bootstrap complete ==="
echo "Restart your terminal or run: exec zsh"
